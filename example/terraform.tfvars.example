# Azure Configuration
subscription_id     = "12345678-1234-5678-9012-123456789012"
resource_group_name = "my-dns-resource-group"

# YAML Zone Files
# List of YAML files containing DNS zone configurations
# File names should match the DNS zone name (e.g., example.com.yaml)
zone_files = [
  "zones/example.com.yaml",
  "zones/sub.example.com.yaml"
]

# Alternative: DNS Records as Terraform Variables
